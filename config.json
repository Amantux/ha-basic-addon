{
  "name": "HA Basic Add-on",
  "version": "0.1.8",
  "slug": "ha-basic-addon",
  "description": "A minimal supervisor add-on that exposes a health endpoint for Home Assistant integrations.",
  "url": "https://github.com/Amantux/ha-basic-addon",
  "arch": [
    "amd64",
    "armv7",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "options": {
    "host": "0.0.0.0",
    "port": 8080,
    "greeting": "Hello from HA Basic Add-on!"
  },
  "ports": {
    "8080/tcp": 8080
  },
  "ingress": true,
  "map": [
    "data:rw"
  ],
  "discovery": [
    "ha_basic_addon"
  ],
  "schema": {
    "host": "str?",
    "port": "int?",
    "greeting": "str?"
  }
}
